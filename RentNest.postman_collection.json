{
  "info": {
    "name": "RentNest API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://rentnest-backend-xzlu.onrender.com" },
    { "key": "token", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "rentalRequestId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Tenant\",\n  \"email\": \"testtenant@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@rentnest.com\",\n  \"password\": \"tenant123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        { "name": "Get All Properties", "request": { "method": "GET", "url": "{{baseUrl}}/api/properties" } },
        { "name": "Get Property By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/properties/{{propertyId}}" } },
        { "name": "Get Categories", "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" } }
      ]
    },
    {
      "name": "Landlord",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nice Apartment\",\n  \"description\": \"Spacious 2 bedroom apartment near the market.\",\n  \"address\": \"123 Main Road\",\n  \"city\": \"Rangpur\",\n  \"price\": 9000,\n  \"bedrooms\": 2,\n  \"bathrooms\": 1,\n  \"amenities\": [\"Parking\"],\n  \"images\": [],\n  \"categoryId\": \"{{categoryId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/landlord/properties"
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 9500\n}" },
            "url": "{{baseUrl}}/api/landlord/properties/{{propertyId}}"
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/landlord/properties/{{propertyId}}"
          }
        },
        {
          "name": "Get My Listing Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/landlord/requests"
          }
        },
        {
          "name": "Respond To Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\"\n}" },
            "url": "{{baseUrl}}/api/landlord/requests/{{rentalRequestId}}"
          }
        }
      ]
    },
    {
      "name": "Rentals (Tenant)",
      "item": [
        {
          "name": "Create Rental Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"moveInDate\": \"2026-08-01\",\n  \"message\": \"I would like to rent this.\"\n}"
            },
            "url": "{{baseUrl}}/api/rentals"
          }
        },
        {
          "name": "Get My Rental Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/rentals"
          }
        },
        {
          "name": "Get Rental Request By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/rentals/{{rentalRequestId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (Stripe Checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\"\n}" },
            "url": "{{baseUrl}}/api/payments/create"
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"sessionId\": \"cs_test_xxx\"\n}" },
            "url": "{{baseUrl}}/api/payments/confirm"
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great place to stay!\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"BANNED\"\n}" },
            "url": "{{baseUrl}}/api/admin/users/USER_ID"
          }
        },
        {
          "name": "Get All Properties (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/properties"
          }
        },
        {
          "name": "Get All Rentals (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/rentals"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Penthouse\"\n}" },
            "url": "{{baseUrl}}/api/admin/categories"
          }
        }
      ]
    }
  ]
}
